# OPENROUTER_API_KEY: Required for OpenRouter API calls.
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# OPENROUTER_MODEL: The model to use for level generation.
# Default: openrouter/free (free tier, 200k context)
# List of free models: https://openrouter.ai/models?max_price=0
OPENROUTER_MODEL="openrouter/free"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
